# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WhatsApp (Wassist) — https://docs.wassist.app
WASSIST_API_KEY=
WASSIST_SIGNING_SECRET=
WASSIST_PRODUCER_CONVERSATION_ID=
PRODUCER_WHATSAPP=

# LLM
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Producer negotiation defaults
PRODUCER_NAME=
PUB_TARGET=50
PUB_FLOOR=40
POINTS_TARGET=3
POINTS_FLOOR=2
MIN_UPFRONT=500
USAGE_MODELS=exclusive sale, non-exclusive lease, points-on-master
RELATIONSHIP_MODE=collaborative repeat counterparty; protect the relationship over the last point

# PayPal sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENV=sandbox

# Modal CLAP endpoints (optional — falls back to pseudo-embed)
MODAL_CLAP_TEXT_URL=
MODAL_CLAP_AUDIO_URL=

# Email (SendGrid or log-only)
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# App URL for PayPal return URLs
NEXT_PUBLIC_APP_URL=
